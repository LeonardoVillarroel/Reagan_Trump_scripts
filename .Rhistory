library(dplyr)
library(dplyr)
library(quanteda.textstats)
# Assume corpus_df already contains all readability metrics
# Function to get the chunk(s) with the minimum value of a metric per speaker
get_min_chunk <- function(data, metric){
data %>%
group_by(speaker) %>%
filter(.data[[metric]] == min(.data[[metric]], na.rm = TRUE)) %>%
select(chunk_id, speaker, text, Flesch, FleschKincaid, DaleChall, SMOG, GunningFog) %>%
ungroup() %>%
mutate(metric = metric)
}
# List of metrics
metrics <- c("Flesch", "FleschKincaid", "DaleChall", "SMOG", "GunningFog")
# Apply function to each metric and combine results
min_chunks_table <- bind_rows(lapply(metrics, function(m) get_min_chunk(corpus_df, m)))
# Optional: reorder columns for readability
min_chunks_table <- min_chunks_table %>%
select(metric, chunk_id, speaker, Flesch, FleschKincaid, DaleChall, SMOG, GunningFog, text)
# View table
min_chunks_table
