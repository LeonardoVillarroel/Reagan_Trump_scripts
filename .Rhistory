library(dplyr)
# Function to display chunk text
show_chunk <- function(chunk) {
cat("Chunk ID:", chunk$chunk_id, "\n")
cat("Speaker:", chunk$speaker, "\n")
cat("Tokens:", chunk$ntokens, " Sentences:", chunk$nsentences, "\n")
cat("Flesch:", chunk$Flesch, " Flesch-Kincaid:", chunk$Flesch.Kincaid, "\n")
cat("Text:\n")
cat(chunk$text, sep = "\n")
cat("\n\n----------------------------\n\n")
}
# Speakers
speakers <- unique(corpus_df$speaker)
for(s in speakers) {
df_s <- corpus_df %>% filter(speaker == s)
# Least readable chunk by Flesch (lower = harder)
min_f <- df_s[which.min(df_s$Flesch), ]
cat("=== Least Readable Chunk by Flesch for", s, "===\n")
show_chunk(min_f)
# Least readable chunk by Flesch-Kincaid (higher = harder)
max_fk <- df_s[which.max(df_s$Flesch.Kincaid), ]
cat("=== Least Readable Chunk by Flesch-Kincaid for", s, "===\n")
show_chunk(max_fk)
}
