library(tidyr)
Fleasch_Ease <- Flesch
plot_df <- corpus_df %>%
select(speaker, Flesch, FleschKincaid) %>%  # just column names
pivot_longer(
cols = c(Flesch, FleschKincaid),
names_to = "metric",
values_to = "value"
