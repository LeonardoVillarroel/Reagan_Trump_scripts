library(dplyr)
library(tidyr)
library(ggplot2)
# -----------------------------
# 1. Prepare data for plotting
# -----------------------------
plot_df <- corpus_df %>%
select(speaker, Flesch, FleschKincaid) %>%  # just select existing columns
pivot_longer(
cols = c(Flesch, FleschKincaid),
names_to = "metric",
values_to = "value"
)
# -----------------------------
# 2. Plot boxplots
# -----------------------------
ggplot(plot_df, aes(x = speaker, y = value, fill = speaker)) +
geom_boxplot(alpha = 0.7, outlier.color = "red", outlier.shape = 16) +
facet_wrap(~ metric, ncol = 2, scales = "free_y") +
labs(
title = "Distribution of Readability Scores by Speaker",
x = "Speaker",
y = "Score"
) +
theme_minimal(base_size = 14) +
theme(
legend.position = "none",
axis.text.x = element_text(angle = 30, hjust = 1)
)
